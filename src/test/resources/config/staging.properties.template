# ============================================================
# Staging Environment Configuration — TEMPLATE
# ============================================================
#
# SETUP: Copy this file to 'staging.properties' and fill in
#        your environment-specific values.
#
#   cp staging.properties.template staging.properties
#
# WARNING: Never commit 'staging.properties' — it contains secrets.
#          Only this template file is tracked in Git.
# ============================================================

env=staging

# --- App Paths (staging build) ---
android.app.path=src/test/resources/apps/app-release.apk
ios.app.path=src/test/resources/apps/app-staging.ipa

# --- App Bundle ID ---
app.bundle.id=

# --- API Base URL (for test data setup) ---
api.base.url=

# --- Partner Integration API (Invite Member) ---
api.invite.base.url=
api.invite.account.id=
api.invite.ignore.signature=true
api.phone.counter.file=src/test/resources/config/.phone_counter

# --- Appium Server Management ---
# Set appium.auto.manage=false for CI/CD where Appium is managed externally
appium.auto.manage=true
appium.server.host=127.0.0.1
appium.server.port=4723
# Update these to match YOUR machine's Node.js and Appium paths:
appium.node.path=/path/to/node
appium.binary.path=/path/to/appium

# --- Test Credentials ---
test.mobile.number=
test.otp=


