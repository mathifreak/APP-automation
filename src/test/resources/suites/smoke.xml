<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Run: make test-module MODULE=smoke -->
<suite name="Smoke Batch" verbose="2" parallel="none" thread-count="1">

    <listeners>
        <listener class-name="com.pice.listeners.ExtentReportListener"/>
        <listener class-name="com.pice.listeners.RetryTransformer"/>
    </listeners>

    <test name="[Batch-1] Smoke" preserve-order="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.pice.tests.smoke.AppLaunchSmokeTest"/>
        </classes>
    </test>

</suite>
